<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.shape.Circle?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.werewolf.client.ui.LoginController"
           styleClass="root app-bg">

   <!-- Center Card — maxHeight giữ form không bị tràn -->
   <VBox alignment="CENTER" maxWidth="440" spacing="0" fillWidth="true"
         styleClass="glass-pane" StackPane.alignment="CENTER">
       <padding><Insets top="26" right="38" bottom="22" left="38"/></padding>

       <!-- ── LOGO ────────────────────────────────── -->
       <VBox alignment="CENTER" spacing="4">
           <HBox alignment="CENTER" spacing="14">
               <!-- Wolf icon circle -->
               <StackPane>
                   <Circle radius="26"
                            style="-fx-fill: linear-gradient(to bottom right, rgba(130,60,255,0.24), rgba(180,20,60,0.18));
                                   -fx-stroke: rgba(140,80,255,0.38); -fx-stroke-width: 2;
                                   -fx-effect: dropshadow(gaussian, rgba(130,60,255,0.65), 22, 0, 0, 0);"/>
                   <SVGPath content="M20 2 L28 10 L36 4 L34 20 L40 30 L30 28 L20 38 L10 28 L0 30 L6 20 L4 4 L12 10 Z"
                            scaleX="0.75" scaleY="0.75"
                            translateX="-20" translateY="-19"
                            styleClass="logo-mark"/>
               </StackPane>
               <!-- Title -->
               <VBox alignment="CENTER_LEFT" spacing="2">
                   <Label text="MA SÓI"
                          style="-fx-font-size: 30px; -fx-font-weight: 900; -fx-text-fill: white;
                                 -fx-effect: dropshadow(gaussian, rgba(140,80,255,0.55), 14, 0, 0, 0);"/>
                   <Label text="Đêm xuống — Ai sẽ sống sót?" styleClass="sub-header-label"/>
               </VBox>
           </HBox>

           <!-- Decorative divider -->
           <HBox alignment="CENTER" spacing="8" style="-fx-padding: 10 0 14 0;">
               <Region style="-fx-background-color: linear-gradient(to right, transparent, rgba(130,80,230,0.42));
                              -fx-pref-height: 1;" HBox.hgrow="ALWAYS"/>
               <Label text="✦" style="-fx-text-fill: rgba(130,80,230,0.55); -fx-font-size: 12px;"/>
               <Label text="WEREWOLF ONLINE"
                      style="-fx-text-fill: rgba(180,145,255,0.48); -fx-font-size: 9.5px;
                             -fx-font-weight: 900; -fx-letter-spacing: 2px;"/>
               <Label text="✦" style="-fx-text-fill: rgba(130,80,230,0.55); -fx-font-size: 12px;"/>
               <Region style="-fx-background-color: linear-gradient(to left, transparent, rgba(130,80,230,0.42));
                              -fx-pref-height: 1;" HBox.hgrow="ALWAYS"/>
           </HBox>
       </VBox>

       <!-- ── TABS ───────────────────────────────── -->
       <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS" maxWidth="Infinity">

          <!-- LOGIN TAB -->
          <Tab text="Đăng Nhập" fx:id="loginTab">
             <VBox spacing="14" alignment="TOP_CENTER" fillWidth="true">
                <padding><Insets top="20" bottom="6"/></padding>

                <VBox spacing="5" maxWidth="Infinity">
                    <Label text="TÊN ĐĂNG NHẬP" styleClass="section-label"/>
                    <TextField fx:id="loginUsernameField" promptText="Nhập username..." maxWidth="Infinity"/>
                </VBox>

                <VBox spacing="5" maxWidth="Infinity">
                    <Label text="MẬT KHẨU" styleClass="section-label"/>
                    <PasswordField fx:id="loginPasswordField" promptText="Nhập mật khẩu..."
                                  onAction="#handleLogin" maxWidth="Infinity"/>
                </VBox>

                <Region prefHeight="4"/>
                <Button fx:id="loginButton" text="⚔  VÀO GAME" onAction="#handleLogin"
                        maxWidth="Infinity" styleClass="button gold"
                        style="-fx-font-size: 14px; -fx-padding: 12 0;"/>
             </VBox>
          </Tab>

          <!-- REGISTER TAB -->
          <Tab text="Đăng Ký" fx:id="registerTab">
             <VBox spacing="11" alignment="TOP_CENTER" fillWidth="true">
                <padding><Insets top="18" bottom="6"/></padding>

                <VBox spacing="5" maxWidth="Infinity">
                    <Label text="TÊN ĐĂNG NHẬP" styleClass="section-label"/>
                    <TextField fx:id="registerUsernameField" promptText="Tối thiểu 3 ký tự..." maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="5" maxWidth="Infinity">
                    <Label text="MẬT KHẨU" styleClass="section-label"/>
                    <PasswordField fx:id="registerPasswordField" promptText="Tối thiểu 4 ký tự..." maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="5" maxWidth="Infinity">
                    <Label text="TÊN HIỂN THỊ TRONG GAME" styleClass="section-label"/>
                    <TextField fx:id="displayNameField" promptText="Tên bạn muốn được gọi..." maxWidth="Infinity"/>
                </VBox>

                <Region prefHeight="2"/>
                <Button fx:id="registerButton" text="✨  ĐĂNG KÝ NGAY" onAction="#handleRegister"
                        maxWidth="Infinity" styleClass="button success"
                        style="-fx-font-size: 13px; -fx-padding: 11 0;"/>
             </VBox>
          </Tab>
       </TabPane>

       <!-- ── STATUS ─────────────────────────────── -->
       <VBox style="-fx-padding: 10 0 0 0;">
           <Label fx:id="statusLabel" text="" wrapText="true" textAlignment="CENTER"
                  maxWidth="Infinity" styleClass="muted"
                  style="-fx-font-size: 12px; -fx-alignment: CENTER;"/>
       </VBox>
   </VBox>

   <!-- Footer -->
   <Label text="Werewolf v2.0  •  Ma Sói Online"
          style="-fx-text-fill: rgba(180,145,255,0.16); -fx-font-size: 10.5px; -fx-padding: 0 0 10 0;"
          StackPane.alignment="BOTTOM_CENTER"/>

</StackPane>
