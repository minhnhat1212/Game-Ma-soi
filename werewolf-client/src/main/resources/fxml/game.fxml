<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.werewolf.client.ui.GameController"
            styleClass="root app-bg app-shell">

   <!-- TOP HUD: Phase & Time -->
   <top>
      <VBox spacing="10" styleClass="top-bar">
         <HBox spacing="20" alignment="CENTER">

            <!-- Round badge -->
            <HBox spacing="8" alignment="CENTER"
                  style="-fx-background-color: rgba(130,80,230,0.14); -fx-background-radius: 24;
                         -fx-border-color: rgba(130,80,230,0.32); -fx-border-width: 1; -fx-border-radius: 24;
                         -fx-padding: 6 16 6 12;">
                <Circle radius="5"
                        style="-fx-fill: #a78bfa; -fx-effect: dropshadow(gaussian, rgba(167,139,250,0.70), 8, 0, 0, 0);"/>
                <Label fx:id="roundLabel" text="VÒNG 1"
                       style="-fx-text-fill: #c4b5fd; -fx-font-weight: 900; -fx-font-size: 14px;"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Phase center display -->
            <VBox alignment="CENTER" spacing="3">
                <Label text="TRẠNG THÁI HIỆN TẠI" styleClass="section-label" style="-fx-font-size: 9.5px;"/>
                <Label fx:id="phaseLabel" text="PHA: CHỜ" styleClass="header-label" style="-fx-font-size: 26px;"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Timer -->
            <VBox alignment="CENTER_RIGHT" spacing="3">
                <Label text="THỜI GIAN" styleClass="section-label" style="-fx-font-size: 9.5px;"/>
                <Label fx:id="timerLabel" text="01:00"
                       style="-fx-text-fill: #f87171; -fx-font-size: 26px; -fx-font-weight: 900;
                              -fx-font-family: 'Courier New';
                              -fx-effect: dropshadow(gaussian, rgba(248,113,113,0.55), 10, 0, 0, 0);"/>
            </VBox>

         </HBox>

         <Region style="-fx-background-color: rgba(130,80,230,0.12); -fx-pref-height: 1;"/>

         <Label fx:id="phaseDescriptionLabel" text="Đang chờ người chơi..."
                style="-fx-text-fill: #ddd6fe; -fx-font-size: 13px; -fx-alignment: CENTER;
                       -fx-opacity: 0.85;" maxWidth="Infinity"/>
      </VBox>
   </top>

   <!-- MAIN CENTER -->
   <center>
      <SplitPane dividerPositions="0.70" styleClass="split-pane"
                 style="-fx-padding: 16 0 0 0;">

         <!-- LEFT: PLAY AREA -->
         <VBox spacing="16" styleClass="card">
            <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

            <!-- Section header -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Circle radius="5"
                        style="-fx-fill: #60a5fa; -fx-effect: dropshadow(gaussian, rgba(96,165,250,0.70), 8, 0, 0, 0);"/>
                <Label text="DANH SÁCH NGƯỜI CHƠI" styleClass="section-label"/>
            </HBox>

            <!-- Player grid -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane">
               <FlowPane fx:id="playerPane" hgap="14" vgap="14" prefWrapLength="600"
                         style="-fx-padding: 8px;"/>
            </ScrollPane>

            <!-- Action Panels stacked -->
            <StackPane>
                <!-- 1. Action/Vote Panel -->
                <VBox fx:id="actionPanel" spacing="14" visible="false" styleClass="glass-pane">
                   <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

                   <HBox alignment="CENTER_LEFT" spacing="10">
                       <Label text="HÀNH ĐỘNG CỦA BẠN"
                              style="-fx-font-weight: 900; -fx-text-fill: #fbbf24; -fx-font-size: 14px;
                                     -fx-effect: dropshadow(gaussian, rgba(251,191,36,0.35), 8, 0, 0, 0);"/>
                       <Region HBox.hgrow="ALWAYS"/>
                       <Label text="Bắt buộc" styleClass="chip chip-gold"/>
                   </HBox>

                   <Label fx:id="actionDescriptionLabel" text="Chọn mục tiêu..."
                          wrapText="true" style="-fx-text-fill: #ddd6fe; -fx-opacity: 0.85;"/>

                   <ListView fx:id="targetList" prefHeight="150" minHeight="110" styleClass="list-view"/>

                   <ListView fx:id="target2List" prefHeight="90" minHeight="70"
                             styleClass="list-view" visible="false" managed="false"/>

                   <Button fx:id="submitActionButton" text="✔  XÁC NHẬN HÀNH ĐỘNG"
                           maxWidth="Infinity" styleClass="button success"
                           style="-fx-font-size: 13.5px; -fx-padding: 12 0;"/>

                   <!-- Special Abilities -->
                   <VBox fx:id="specialAbilityPanel" spacing="10" visible="false" managed="false"
                         style="-fx-padding: 8 0 0 0;">
                       <Region style="-fx-background-color: rgba(255,255,255,0.07); -fx-pref-height: 1;"/>
                       <Label text="⚡ KỸ NĂNG ĐẶC BIỆT  (Dùng 1 lần)"
                              styleClass="section-label"
                              style="-fx-text-fill: #f0abfc;"/>
                       <HBox spacing="8" alignment="CENTER_LEFT">
                           <Button fx:id="guardSelfBtn" text="🛡 Tự bảo vệ"
                                   visible="false" managed="false"
                                   onAction="#handleGuardSelf" styleClass="button small"
                                   style="-fx-font-size: 12px;"/>
                           <Button fx:id="seerIntuitionBtn" text="🔮 Trực giác"
                                   visible="false" managed="false"
                                   onAction="#handleSeerIntuition" styleClass="button small"
                                   style="-fx-font-size: 12px;"/>
                           <Button fx:id="wolfFrameBtn" text="🎭 Frame người"
                                   visible="false" managed="false"
                                   onAction="#handleWolfFrame" styleClass="button small"
                                   style="-fx-font-size: 12px;"/>
                           <Button fx:id="witchReviveBtn" text="✨ Hồi sinh"
                                   visible="false" managed="false"
                                   onAction="#handleWitchRevive" styleClass="button gold small"
                                   style="-fx-font-size: 12px;"/>
                           <Button fx:id="witchSilenceBtn" text="🤫 Câm chat"
                                   visible="false" managed="false"
                                   onAction="#handleWitchSilence" styleClass="button small"
                                   style="-fx-font-size: 12px;"/>
                       </HBox>
                   </VBox>
                </VBox>

                <!-- 2. Vote Result Panel -->
                <VBox fx:id="voteResultPanel" spacing="14" visible="false"
                      styleClass="glass-pane card-wolf">
                   <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                   <HBox alignment="CENTER_LEFT" spacing="10">
                       <Circle radius="5"
                               style="-fx-fill: #f87171; -fx-effect: dropshadow(gaussian, rgba(248,113,113,0.70), 8, 0, 0, 0);"/>
                       <Label text="KẾT QUẢ BỎ PHIẾU"
                              style="-fx-font-weight: 900; -fx-text-fill: #fca5a5; -fx-font-size: 15px;"/>
                   </HBox>
                   <Region style="-fx-background-color: rgba(248,113,113,0.20); -fx-pref-height: 1;"/>
                   <Label fx:id="voteResultLabel" text="" wrapText="true"
                          style="-fx-font-size: 13.5px; -fx-line-spacing: 5px; -fx-text-fill: #ddd6fe;"/>
                </VBox>

                <!-- 3. Game End Panel -->
                <VBox fx:id="gameEndPanel" spacing="22" visible="false" alignment="CENTER"
                      styleClass="glass-pane card-gold">
                   <padding><Insets top="34" right="34" bottom="34" left="34"/></padding>

                   <Label text="🏁  KẾT THÚC TRẬN ĐẤU"
                          style="-fx-font-size: 24px; -fx-font-weight: 900; -fx-text-fill: #fbbf24;
                                 -fx-effect: dropshadow(gaussian, rgba(251,191,36,0.50), 14, 0, 0, 2);"/>
                   <Label fx:id="winnerLabel" text="PHE DÂN THẮNG"
                          style="-fx-font-size: 20px; -fx-font-weight: 800;"/>

                   <!-- Reward Dashboard -->
                   <VBox fx:id="rewardPanel" spacing="16"
                         style="-fx-background-color: rgba(0,0,0,0.45); -fx-background-radius: 16;
                                -fx-border-color: rgba(251,191,36,0.16); -fx-border-width: 1;
                                -fx-border-radius: 16; -fx-padding: 22; -fx-min-width: 380px;">
                       <Label text="📊  TỔNG KẾT PHẦN THƯỞNG" styleClass="section-label"/>

                       <HBox spacing="14" alignment="CENTER">
                           <VBox alignment="CENTER" spacing="6" styleClass="stat-box" HBox.hgrow="ALWAYS">
                               <Label text="✨ KINH NGHIỆM"
                                      style="-fx-text-fill: #93c5fd; -fx-font-size: 10.5px; -fx-font-weight: 900;"/>
                               <Label fx:id="xpGainedLabel" text="+0"
                                      style="-fx-text-fill: #93c5fd; -fx-font-size: 26px; -fx-font-weight: 900;
                                             -fx-effect: dropshadow(gaussian, rgba(147,197,253,0.45), 10, 0, 0, 0);"/>
                           </VBox>
                           <VBox alignment="CENTER" spacing="6" styleClass="stat-box" HBox.hgrow="ALWAYS">
                               <Label text="🏆 THƯỞNG THÊM"
                                      style="-fx-text-fill: #5eead4; -fx-font-size: 10.5px; -fx-font-weight: 900;"/>
                               <Label fx:id="bonusXpLabel" text="+0"
                                      style="-fx-text-fill: #5eead4; -fx-font-size: 26px; -fx-font-weight: 900;
                                             -fx-effect: dropshadow(gaussian, rgba(94,234,212,0.45), 10, 0, 0, 0);"/>
                           </VBox>
                           <VBox alignment="CENTER" spacing="6" styleClass="stat-box" HBox.hgrow="ALWAYS">
                               <Label text="🪙 XU NHẬN ĐƯỢC"
                                      style="-fx-text-fill: #fbbf24; -fx-font-size: 10.5px; -fx-font-weight: 900;"/>
                               <Label fx:id="coinsGainedLabel" text="+0"
                                      style="-fx-text-fill: #fbbf24; -fx-font-size: 26px; -fx-font-weight: 900;
                                             -fx-effect: dropshadow(gaussian, rgba(251,191,36,0.50), 10, 0, 0, 0);"/>
                           </VBox>
                       </HBox>

                       <Region style="-fx-background-color: rgba(255,255,255,0.07); -fx-pref-height: 1;"/>

                       <!-- XP Progression -->
                       <VBox spacing="10">
                           <HBox alignment="BOTTOM_LEFT" spacing="10">
                               <Label text="HẠNG HIỆN TẠI:"
                                      styleClass="section-label" style="-fx-padding: 0 0 2 0;"/>
                               <Label fx:id="rankLabel" text="🌱 Tân Binh"
                                      style="-fx-font-size: 18px; -fx-font-weight: 900; -fx-text-fill: #fbbf24;"/>
                               <Region HBox.hgrow="ALWAYS"/>
                               <Label fx:id="xpProgressLabel" text="0 / 100 XP"
                                      style="-fx-text-fill: rgba(196,181,253,0.55); -fx-font-size: 12px; -fx-font-weight: 700;"/>
                           </HBox>
                           <ProgressBar fx:id="xpProgressBar" progress="0"
                                        maxWidth="Infinity" styleClass="progress-bar"/>
                       </VBox>
                   </VBox>

                   <Button text="← QUAY VỀ SẢNH CHÍNH" onAction="#handleBackToMain"
                           styleClass="button" maxWidth="Infinity"
                           style="-fx-font-size: 14px; -fx-padding: 14;"/>
                </VBox>
            </StackPane>
         </VBox>

         <!-- RIGHT: CHAT & ROLE INFO -->
         <VBox spacing="14" styleClass="card">
            <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

            <!-- My Role Box -->
            <VBox styleClass="role-box" alignment="CENTER" spacing="6">
                <Label text="VAI TRÒ CỦA BẠN" styleClass="section-label"/>
                <Label fx:id="myRoleLabel" text="???"
                       style="-fx-font-size: 26px; -fx-font-weight: 900; -fx-text-fill: #fbbf24;
                              -fx-effect: dropshadow(gaussian, rgba(251,191,36,0.50), 14, 0, 0, 0);"/>
            </VBox>

            <!-- Chat section -->
            <VBox spacing="10">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Circle radius="5"
                            style="-fx-fill: #2dd4bf; -fx-effect: dropshadow(gaussian, rgba(45,212,191,0.70), 8, 0, 0, 0);"/>
                    <Label text="KÊNH CHAT CHUNG" styleClass="section-label"/>
                </HBox>
                <Label fx:id="turnInfoLabel" text="Đến lượt: Đang chờ..."
                       styleClass="turn-info-label" maxWidth="Infinity" alignment="CENTER"/>
            </VBox>

            <!-- Chat body -->
            <TextArea fx:id="chatArea" editable="false" VBox.vgrow="ALWAYS"
                      wrapText="true" styleClass="text-area"/>

            <!-- Chat Input -->
            <HBox spacing="10" alignment="CENTER">
               <TextField fx:id="chatInput" promptText="Nhập tin nhắn của bạn..."
                          HBox.hgrow="ALWAYS" onAction="#handleSendChat"/>
               <Button text="Gửi" onAction="#handleSendChat"
                       styleClass="button small"
                       style="-fx-min-width: 58px; -fx-font-size: 13px; -fx-padding: 10 14;"/>
            </HBox>
         </VBox>

      </SplitPane>
   </center>

   <bottom>
      <HBox style="-fx-padding: 8 0 0 0;">
         <Label fx:id="statusLabel" text="Hệ thống ổn định"
                styleClass="muted" style="-fx-font-size: 11px;"/>
      </HBox>
   </bottom>

</BorderPane>