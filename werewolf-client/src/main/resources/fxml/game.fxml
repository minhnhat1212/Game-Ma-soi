<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.werewolf.client.ui.GameController" 
            styleClass="root app-bg app-shell">
   
   <!-- TOP HUD: Phase & Time -->
   <top>
      <VBox spacing="5" styleClass="top-bar">
         <HBox spacing="20" alignment="CENTER">
            <Label fx:id="roundLabel" text="VÒNG 1" style="-fx-text-fill: #a29bfe; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="phaseLabel" text="PHA: CHỜ" styleClass="header-label" style="-fx-font-size: 24px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="timerLabel" text="00:60" style="-fx-text-fill: #ff7675; -fx-font-size: 20px; -fx-font-weight: bold; -fx-font-family: 'Courier New';"/>
         </HBox>
         <Label fx:id="phaseDescriptionLabel" text="Đang chờ người chơi..." style="-fx-text-fill: #dfe6e9; -fx-alignment: CENTER;" maxWidth="Infinity"/>
      </VBox>
   </top>
   
   <center>
      <SplitPane dividerPositions="0.7" style="-fx-background-color: transparent;">
         <!-- LEFT: PLAY AREA -->
         <VBox spacing="10" styleClass="card">
            <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
            <Label text="NGƯỜI CHƠI" style="-fx-font-weight: bold; -fx-text-fill: #74b9ff;"/>
            
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background: transparent; -fx-background-color: transparent;">
               <FlowPane fx:id="playerPane" hgap="15" vgap="15" prefWrapLength="600" style="-fx-padding: 10px;"/>
            </ScrollPane>
            
            <!-- Action Panels -->
            <StackPane>
                <!-- Selection Panel -->
                <VBox fx:id="actionPanel" spacing="10" visible="false" styleClass="glass-pane">
                   <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                   <Label text="HÀNH ĐỘNG CỦA BẠN" style="-fx-font-weight: bold; -fx-text-fill: #ffd700;"/>
                   <Label fx:id="actionDescriptionLabel" text="Chọn mục tiêu..." wrapText="true"/>
                   <ListView fx:id="targetList" prefHeight="200" minHeight="120" styleClass="list-view"/>
                   <Button fx:id="submitActionButton" text="XÁC NHẬN" maxWidth="Infinity" styleClass="button success"/>
                </VBox>
                
                <!-- Vote Result Panel -->
                <VBox fx:id="voteResultPanel" spacing="10" visible="false" styleClass="glass-pane" style="-fx-background-color: rgba(255, 118, 117, 0.2);">
                   <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                   <Label text="KẾT QUẢ BỎ PHIẾU" style="-fx-font-weight: bold; -fx-text-fill: #ff7675;"/>
                   <Label fx:id="voteResultLabel" text="" wrapText="true"/>
                </VBox>
                
                <!-- Game End Panel -->
                <VBox fx:id="gameEndPanel" spacing="15" visible="false" alignment="CENTER" styleClass="glass-pane" style="-fx-background-color: rgba(255, 215, 0, 0.1);">
                   <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>
                   <Label text="KẾT THÚC GAME" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #ffd700;"/>
                   <Label fx:id="winnerLabel" text="PHE DÂN THẮNG" style="-fx-font-size: 18px;"/>
                   <Button text="QUAY VỀ SẢNH" onAction="#handleBackToMain" styleClass="button"/>
                </VBox>
            </StackPane>
         </VBox>
         
         <!-- RIGHT: CHAT & INFO -->
         <VBox spacing="10" styleClass="card">
            <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
            <VBox styleClass="glass-pane">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                <Label text="VAI TRÒ CỦA BẠN" style="-fx-font-size: 10px; -fx-text-fill: #b2bec3;"/>
                <Label fx:id="myRoleLabel" text="???" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #ffd700;"/>
            </VBox>
            
            <Label text="CHAT BOX" style="-fx-font-weight: bold; -fx-text-fill: #fab1a0;"/>
            <Label fx:id="turnInfoLabel" text="Đến lượt: Đang chờ..." styleClass="turn-info-label"/>
            <TextArea fx:id="chatArea" editable="false" VBox.vgrow="ALWAYS" wrapText="true" 
                      style="-fx-control-inner-background: rgba(0,0,0,0.3); -fx-text-fill: white; -fx-font-family: 'Segoe UI Emoji';"/>
            
            <HBox spacing="5">
               <TextField fx:id="chatInput" promptText="Nhập tin nhắn..." HBox.hgrow="ALWAYS" onAction="#handleSendChat"/>
               <Button text="Gửi" onAction="#handleSendChat" styleClass="button small"/>
            </HBox>
         </VBox>
      </SplitPane>
   </center>
   
   <bottom>
      <Label fx:id="statusLabel" text="" style="-fx-font-size: 10px; -fx-text-fill: #636e72; -fx-padding: 2px;"/>
   </bottom>
</BorderPane>